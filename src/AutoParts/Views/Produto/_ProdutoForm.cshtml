@model AutoParts.ViewModels.ProdutoFormViewModel

<div class="row">

    <!-- COLUNA ESQUERDA -->

    <div class="col-lg-8">

        <!-- Dados Gerais -->

        <div class="card shadow-sm border-0 mb-4">

            <div class="card-header bg-white">

                <h5 class="mb-0">

                    <i class="bi bi-box-seam me-2 text-primary"></i>

                    Dados Gerais

                </h5>

            </div>

            <div class="card-body">

                <div class="row g-3">

                    <div class="col-md-3">

                        <label asp-for="Codigo" class="form-label"></label>

                        <input asp-for="Codigo" class="form-control" />

                        <span asp-validation-for="Codigo" class="text-danger"></span>

                    </div>

                    <div class="col-md-9">

                        <label asp-for="Descricao" class="form-label"></label>

                        <input asp-for="Descricao" class="form-control" />

                        <span asp-validation-for="Descricao" class="text-danger"></span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="CategoriaId" class="form-label"></label>

                        <select asp-for="CategoriaId"
                                asp-items="Model.Categorias"
                                class="form-select">

                            <option value="">Selecione...</option>

                        </select>

                        <span asp-validation-for="CategoriaId" class="text-danger"></span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="MarcaId" class="form-label"></label>

                        <select asp-for="MarcaId"
                                asp-items="Model.Marcas"
                                class="form-select">

                            <option value="">Selecione...</option>

                        </select>

                        <span asp-validation-for="MarcaId" class="text-danger"></span>

                    </div>

                </div>

            </div>

        </div>





        <!-- Valores -->

        <div class="card shadow-sm border-0 mb-4">

            <div class="card-header bg-white">

                <h5 class="mb-0">

                    <i class="bi bi-currency-dollar me-2 text-success"></i>

                    Valores

                </h5>

            </div>

            <div class="card-body">

                <div class="row g-3">

                    <div class="col-md-6">

                        <label asp-for="PrecoCompra" class="form-label"></label>

                        <input asp-for="PrecoCompra"
                               class="form-control"
                               type="number"
                               step="0.01" />

                        <span asp-validation-for="PrecoCompra"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="PrecoVenda" class="form-label"></label>

                        <input asp-for="PrecoVenda"
                               class="form-control"
                               type="number"
                               step="0.01" />

                        <span asp-validation-for="PrecoVenda"
                              class="text-danger"></span>

                    </div>

                </div>

            </div>

        </div>

    </div>





    <!-- COLUNA DIREITA -->

    <div class="col-lg-4">

        <!-- Estoque -->

        <div class="card shadow-sm border-0 mb-4">

            <div class="card-header bg-white">

                <h5 class="mb-0">

                    <i class="bi bi-boxes me-2 text-warning"></i>

                    Estoque

                </h5>

            </div>

            <div class="card-body">

                <div class="mb-3">

                    <label asp-for="Estoque"
                           class="form-label"></label>

                    <input asp-for="Estoque"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label asp-for="EstoqueMinimo"
                           class="form-label"></label>

                    <input asp-for="EstoqueMinimo"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label asp-for="Localizacao"
                           class="form-label">
                        Localização
                    </label>

                    <input asp-for="Localizacao"
                           class="form-control"
                           placeholder="Ex.: A1-05" />

                </div>

                <div class="form-check form-switch mt-4">

                    <input asp-for="Ativo"
                           class="form-check-input" />

                    <label asp-for="Ativo"
                           class="form-check-label">

                        Produto Ativo

                    </label>

                </div>

            </div>

        </div>





        <!-- Observações -->

        <div class="card shadow-sm border-0">

            <div class="card-header bg-white">

                <h5 class="mb-0">

                    <i class="bi bi-chat-left-text me-2 text-secondary"></i>

                    Observações

                </h5>

            </div>

            <div class="card-body">

                <textarea asp-for="Observacoes"
                          class="form-control"
                          rows="8"
                          placeholder="Observações do produto..."></textarea>

            </div>

        </div>

    </div>

</div>





<!-- Botões -->

<div class="d-flex justify-content-end mt-4 gap-2">

    <a asp-action="Index"
       class="btn btn-outline-secondary">

        <i class="bi bi-arrow-left"></i>

        Cancelar

    </a>

    <button type="submit"
            class="btn btn-primary px-4">

        <i class="bi bi-check-circle"></i>

        Salvar Produto

    </button>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}